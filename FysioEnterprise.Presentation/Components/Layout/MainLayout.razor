@using FysioEnterprise.Presentation.Components.Pages.ChildComponents
@using FysioEnterprise.Presentation.Service
@using Radzen.Blazor
@inherits LayoutComponentBase
@inject LogInContext Context
@implements IDisposable
@inject NavigationManager NavManager

<header class="site-header"> @*Main navigationbar with Logo*@
    <nav class="topbar" aria-label="Applikation header">
        <NavLink href="/" class="brand-link" Match="NavLinkMatch.All">
            <img src="/images/FysioFuncLogo.jpg" alt="FysioFunc Logo" class="logo-image" />
        </NavLink>

        <span class="spacer"></span>

        @if (Context.IsLoggedIn) @*Logout button with current clinic address. Only visible after logging in, to prevent confusion*@
        {
            <aside class="top-right">
                <details class="profile-dropdown">
                    <summary class="user-pill">
                        <span class="user-avatar">
                            @(!string.IsNullOrEmpty(Context.StaffName) ? Context.StaffName.FirstOrDefault() : 'U')
                        </span>
                        <span class="pill-text">@Context.StaffName</span>
                        <RadzenIcon Icon="expand_more" />
                    </summary>
                    <nav class="dropdown-menu" aria-label="Profil menu">
                        <p class="dropdown-clinic">
                            <RadzenIcon Icon="location_on" />
                            @Context.ClinicName
                        </p>
                        <hr class="dropdown-divider" />
                        <button class="dropdown-item logout-btn" @onclick="Logout">
                            <RadzenIcon Icon="logout" />
                            Log ud
                        </button>
                    </nav>
                </details>
            </aside>
        }
    </nav>
</header>

@if (Context.IsLoggedIn) @*Second navigationbar only visible after logging in since it stores all the paths to move around the website*@
{
    <div class="subnav-container">
        <nav class="subnav-bar" aria-label="Side navigation">
            <NavLink href="/calendar" class="subnav-link"><RadzenIcon Icon="event_note" />Kalender</NavLink>
            <NavLink href="/clients" class="subnav-link"><RadzenIcon Icon="group" />Klienter</NavLink>
            <NavLink href="/promotions" class="subnav-link"><RadzenIcon Icon="sell" />Promoveringer</NavLink>
            <NavLink href="/statistics" class="subnav-link"><RadzenIcon Icon="bar_chart" />Statistikker</NavLink>
        </nav>
    </div>
}

<main class="page-content">
    @Body
    <NotificationHelperComponent /> 
</main>
