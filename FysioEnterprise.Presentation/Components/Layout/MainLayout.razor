@using FysioEnterprise.Presentation.Service
@using Radzen.Blazor;
@inherits LayoutComponentBase
@inject LogInContext Context
@implements IDisposable

<header class="site-header">
    <nav class="topbar">
        <NavLink href="/" class="brand-link" Match="NavLinkMatch.All">
            <img src="/images/FysioFuncLogo.jpg" alt="FysioFunc Logo" class="logo-image" />
        </NavLink>

        <div class="spacer"></div>

        @if (Context.IsLoggedIn)
        {
            <aside class="top-right">
                <div class="user-pill">
                    <span class="pill-text">@Context.ClinicName · @Context.StaffName</span>
                    <RadzenIcon Icon="expand_more" Style="font-size: 14px;" />
                </div>
            </aside>
        }
    </nav>
</header>

@if (Context.IsLoggedIn)
{
    <nav class="subnav">
        <NavLink href="/clients" class="subnav-link"><RadzenIcon Icon="group" />Clients</NavLink>
        <NavLink href="/promotions" class="subnav-link"><RadzenIcon Icon="sell" />Promotions</NavLink>
        <NavLink href="/sessions" class="subnav-link"><RadzenIcon Icon="event_note" />Sessions</NavLink>
        <NavLink href="/bookings" class="subnav-link"><RadzenIcon Icon="calendar_month" />Bookings</NavLink>
        <NavLink href="/statistics" class="subnav-link"><RadzenIcon Icon="bar_chart" />Statistics</NavLink>
    </nav>
}

<main class="page-content">
    @Body
</main>

@code {
    protected override void OnInitialized()
    {
        Context.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Context.OnChange -= StateHasChanged;
    }
}