@using FysioEnterprise.Presentation.Service.Helpers
@inject NotificationHelper Notification
@implements IDisposable

@if (_isVisible)
{
    <aside class="notification @(Notification.IsSuccess ? "success" : "error")">
        <span>@Notification.Message</span>
        <button @onclick="Notification.Clear">✕</button>
    </aside>
}

@code {
    private bool _isVisible = false;
    private System.Threading.CancellationTokenSource? _timerCts;

    protected override void OnInitialized()
        => Notification.OnChange += HandleChange;

    private async void HandleChange()
    {
        _isVisible = Notification.IsVisible;
        await InvokeAsync(StateHasChanged);

        if (_isVisible)
        {
            StartAutoDismissTimer();
        }
    }

    private async void StartAutoDismissTimer()
    {
        _timerCts?.Cancel();
        _timerCts?.Dispose();
        _timerCts = new System.Threading.CancellationTokenSource();

        try
        {
            await Task.Delay(5000, _timerCts.Token);

            Notification.Clear();
        }
        catch (TaskCanceledException)
        {
            //Set up in case of task being aborted
        }
    }

    public void Dispose()
    {
        Notification.OnChange -= HandleChange;
        _timerCts?.Cancel();
        _timerCts?.Dispose();
    }
}
