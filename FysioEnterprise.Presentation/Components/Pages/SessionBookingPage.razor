@page "/calendar"
@rendermode InteractiveServer
@using Radzen.Blazor;
@using System.Globalization
@inject IJSRuntime JS

<section class="booking-page">

    <header class="booking-header">
        <h1 class="booking-title">@clinicName - Kalender</h1>
    </header>

    <header class="booking-toolbar">
        <nav class="toolbar-left" aria-label="Booking handlinger" style="min-width: auto; flex: 1; justify-content: flex-start;">
            <button class="btn-primary" @onclick="GoToCreateSession">
                <RadzenIcon Icon="add" />
                Opret booking
            </button>
            
            <button class="btn-switch" @onclick="ToggleViewMode">
                <RadzenIcon Icon="swap_horiz" />
                Gå til @(CurrentViewMode == CalendarViewMode.Staff ? "Klient" : "Medarbejder") kalender
            </button>

            <label class="search-wrapper" aria-label="Søg i kalender" style="margin-left: 4px;">
                <RadzenIcon Icon="search" class="search-icon" />
                <input type="search"
                       class="calendar-search"
                       placeholder="Søg efter @(CurrentViewMode == CalendarViewMode.Staff ? "medarbejder..." : "klient...")"
                       value="@SearchQuery"
                       @oninput="e => SearchQuery = e.Value?.ToString() ?? string.Empty" />
                @if (!string.IsNullOrEmpty(SearchQuery))
                {
                    <button class="search-clear" @onclick='() => SearchQuery = string.Empty' aria-label="Ryd søgning">
                        <RadzenIcon Icon="close" />
                    </button>
                }
            </label>
        </nav>

        <nav class="toolbar-center" aria-label="Kalender navigation">
            <menu class="view-toggle">
                <li><button class="@(View == "month" ? "active" : "")" @onclick='() => SetView("month")'>Måned</button></li>
                <li><button class="@(View == "week" ? "active" : "")" @onclick='() => SetView("week")'>Uge</button></li>
                <li><button class="@(View == "day" ? "active" : "")" @onclick='() => SetView("day")'>Dag</button></li>
            </menu>

            <nav class="nav-arrows" aria-label="Naviger perioder">
                <button @onclick="NavigateBack" aria-label="Forrige"><RadzenIcon Icon="chevron_left" /></button>
                <strong class="current-range">@GetRangeLabel()</strong>
                <button @onclick="NavigateForward" aria-label="Næste"><RadzenIcon Icon="chevron_right" /></button>
            </nav>

            <button class="btn-today" @onclick="GoToToday">i dag</button>
        </nav>

        <aside class="toolbar-right" style="min-width: auto;">
            <button class="btn-secondary @(HideWeekends ? "weekend-hidden-active" : "")"
                    @onclick="ToggleWeekends"
                    style="display: inline-flex; align-items: center; gap: 6px;">
                <RadzenIcon Icon="@(HideWeekends ? "visibility" : "visibility_off")" />
                @(HideWeekends ? "Vis Weekend" : "Fjern Weekend")
            </button>
        </aside>
    </header>

    @if (View is "week" or "day")
    {
        <article class="calendar-wrap" aria-label="Uge kalender">
            <table class="calendar-table">
                <thead>
                    <tr>
                        <th class="time-gutter-header" scope="col"></th>
                        @foreach (var day in VisibleDays)
                        {
                            <th scope="col"
                                class="day-header @(IsToday(day) ? "today-header" : "")"
                                @onclick="() => DrillToDay(day)">
                                <span class="day-name">@day.ToString("ddd", DanishCulture).ToUpper()</span>
                                <span class="day-number @(IsToday(day) ? "today-circle" : "")">
                                    @day.ToString("d. MMM", DanishCulture)
                                </span>
                            </th>
                        }
                    </tr>
                </thead>
            </table>

            <section class="calendar-body" aria-label="Kalender indhold">

                <aside class="time-gutter" aria-label="Tidslinje">
                    @for (var hour = 0; hour < 24; hour++)
                    {
                        var topPx = hour * SlotHeight * 4;
                        <time class="time-marker" style="top: @(topPx)px">
                            @($"{hour:D2}:00")
                        </time>
                    }
                </aside>

                @foreach (var day in VisibleDays)
                {
                    var isWeekend = day.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
                    var daySessions = GetSessionsForDay(day);
                    var columns = CalculateColumns(daySessions);

                    <section class="day-column
                        @(isWeekend ? "weekend" : "")
                        @(IsToday(day) ? "today-col" : "")
                        @(SelectedCell.HasValue && SelectedCell.Value.Date == day.Date ? "selected-col" : "")"
                             aria-label="@day.ToString("dddd d. MMMM", DanishCulture)">

                        @for (var slot = 0; slot < 96; slot++)
                        {
                            var currentSlot = slot;
                            var slotHour = currentSlot / 4;
                            var slotMinute = (currentSlot % 4) * 15;
                            var isClosed = IsOutsideOpeningHours(day, slotHour);

                            string rowBorderClass;
                            if (slotMinute == 0) rowBorderClass = "hour-border";
                            else if (slotMinute == 30) rowBorderClass = "half-border";
                            else rowBorderClass = "quarter-border";

                            <section class="calendar-slot-row @rowBorderClass @(isClosed ? "closed-hours" : "")"
                                     style="top: @(currentSlot * SlotHeight)px; height: @(SlotHeight)px;"
                                     @onclick="() => OnCellClick(day, slotHour)"
                                     @ondblclick="() => OnColumnDoubleClick(day, slotHour, slotMinute)">
                            </section>
                        }

                        @foreach (var session in daySessions)
                        {
                            var layout = GetSessionLayout(session, columns);
                            <article class="session-block @GetDynamicColorClass(session)"
                                     style="top:@(layout.Top.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))px;height:@(layout.Height.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))px;left:@(layout.Left.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;width:@(layout.Width.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;"
                                     @onclick:stopPropagation="true"
                                     @onclick="() => OnSessionClick(session)"
                                     title="@session.ClientFirstName @session.ClientLastName — @session.SessionTypeName">
                                <time class="session-time">
                                    @session.timeSlot.From.ToString("HH:mm") – @session.timeSlot.To.ToString("HH:mm")
                                </time>
                                @if (CurrentViewMode == CalendarViewMode.Staff)
                                {
                                    <strong class="session-client">@session.StaffFirstName @session.StaffLastname - @GetStaffAuthorisationType(session.StaffFirstName + " " + session.StaffLastname)</strong>
                                }
                                else
                                {
                                    <strong class="session-client">@session.ClientFirstName @session.ClientLastName</strong>
                                }
                                <span class="session-type">@session.SessionTypeName</span>
                            </article>
                        }

                        @if (SelectedCell.HasValue && SelectedCell.Value.Date == day.Date)
                        {
                            var popupTop = TimeToPixels(SelectedCell.Value);
                            <aside class="cell-popup"
                                   style="top:@(popupTop.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))px;"
                                   @onclick:stopPropagation="true">
                                <strong class="popup-time">
                                    @SelectedCell.Value.ToString("HH:mm") – @SelectedCell.Value.AddMinutes(15).ToString("HH:mm")
                                </strong>
                                <p class="popup-date">@day.ToString("dddd d. MMMM", DanishCulture)</p>
                                <select class="popup-select" @onchange="OnSessionTypeSelected">
                                     <option value="" disabled selected hidden>— Vælg Sessionstype —</option>
                                    @foreach (var type in _sessionTypes)
                                    {
                                        <option value="@type.SessionTypeID">@type.SessionTypeName - @GetSessionTypeInMinutes(type)</option>
                                    }
                                </select>
                                <button class="popup-btn"
                                        @onclick="GoToCreateSessionWithSlot"
                                        disabled="@(SelectedSessionTypeId == Guid.Empty)">
                                    Opret booking her
                                </button>
                            </aside>
                        }
                    </section>
                }
            </section>
        </article>
    }

    @if (View == "month")
    {
        <article class="month-wrap" aria-label="Måneds kalender">
            <table class="month-table">
                <thead>
                    <tr>
                        @foreach (var dayName in new[] { "MAN", "TIRS", "ONS", "TORS", "FRE", "LØR", "SØN" })
                        {
                            <th scope="col" class="month-day-header">@dayName</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < MonthDays.Count; i += 7)
                    {
                        <tr>
                            @foreach (var day in MonthDays.Skip(i).Take(7))
                            {
                                var inMonth = day.Month == CurrentDate.Month;
                                var isToday = IsToday(day);
                                var daySessions = GetSessionsForDay(day);

                                <td class="month-cell @(!inMonth ? "out-of-month" : "") @(isToday ? "today-month" : "")"
                                    @onclick="() => DrillToDay(day)">
                                    <span class="month-day-number @(isToday ? "today-circle" : "")">@day.Day</span>
                                    @foreach (var session in daySessions.Take(3))
                                    {
                                        <article class="month-session @GetDynamicColorClass(session)"
                                                 @onclick:stopPropagation="true"
                                                 @onclick="() => OnSessionClick(session)"
                                                 title="@session.ClientFirstName @session.ClientLastName — @session.SessionTypeName">
                                            <time class="session-time" datetime="@session.timeSlot.From.ToString("HH:mm")">
                                                @session.timeSlot.From.ToString("HH:mm") – @session.timeSlot.To.ToString("HH:mm")
                                            </time>
                                            
                                            @if (CurrentViewMode == CalendarViewMode.Staff)
                                            {
                                                <strong class="session-month">@session.StaffFirstName @session.StaffLastname - @GetStaffAuthorisationType(session.StaffFirstName + " " + session.StaffLastname)</strong>
                                            }
                                            else
                                            {
                                                <strong class="session-month">@GetClientName(session.ClientFirstName + " " + session.ClientLastName)</strong>
                                            }
                                            <span class="session-type">@session.SessionTypeName</span>
                                        </article>
                                    }
                                    @if (daySessions.Count > 3)
                                    {
                                        <span class="month-more">+@(daySessions.Count - 3) mere</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </article>
    }

</section>