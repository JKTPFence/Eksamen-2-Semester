@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using FysioEnterprise.Presentation.Service.Helpers
@inject NotificationHelper Notification
@page "/createsession"
@using System.Globalization
@using Radzen.Blazor

<main class="home-wrap">
	<header class="home-header">
		<h1 class="welcome-text">
			@if (_isComboMode)
			{
				<span>Combo booking — session @_comboStep af 2</span>
			}
			else
			{
				<span>Opret booking</span>
			}
		</h1>
		@* Combo toggle *@
		<label class="combo-toggle">
			<input type="checkbox"
				   checked="@_isComboMode"
				   @onchange="() => ToggleComboMode()"
				   disabled="@(_comboStep == 2)" />
			<span>Combo booking</span>
			@if (_isComboMode)
			{
				<span class="combo-badge">2 sessioner</span>
			}
		</label>
	</header>

	@* Step indicator — only show in combo mode *@
	@if (_isComboMode)
	{
		<nav class="combo-steps" aria-label="Combo booking trin">
			<span class="combo-step @(_comboStep == 1 ? "combo-step--active" : "combo-step--done")">
				<span class="combo-step-nr">1</span>
				<span class="combo-step-label">
					@if (_comboStep > 1)
					{
						<span>✓ Session 1</span>
						@if (_firstSession is not null)
						{
							<small>@_firstSession.StartTime.ToString("HH:mm") – @_firstSession.EndTime.ToString("HH:mm")</small>
						}
					}
					else
					{
						<span>Session 1</span>
					}
				</span>
			</span>
			<span class="combo-step-divider">→</span>
			<span class="combo-step @(_comboStep == 2 ? "combo-step--active" : "")">
				<span class="combo-step-nr">2</span>
				<span class="combo-step-label">Session 2</span>
			</span>
		</nav>
	}

	<article class="selection-card">

		@if (Notification.IsVisible)
		{
			<p class="@(Notification.IsSuccess ? "success-message" : "error-message")">
				@Notification.Message
			</p>
		}

		
		@*Client*@
		<section class="form-field">
			<label class="field-label">
				<span class="step-nr">1</span>
				<RadzenIcon Icon="person" Style ="font-size: 18px;" />
				Klient
			</label>
			<select class="form-select" value="@_selectedClientId" @onchange="OnClientChanged" disabled="@(_isComboMode && _comboStep == 2)">
				<option value="@Guid.Empty" disabled>- Vælg Klient -</option>
				@foreach (var client in _clients)
				{
					<option value="@client.ClientID"
							selected="@(client.ClientID == _selectedClientId)">
						@client.ClientFirstName @client.ClientLastName
					</option>
				}
			</select>
		</section>

		@*Start time*@
		<section class="form-field">
			<label class="field-label">
				<span class="step-nr">2</span>
				<RadzenIcon Icon="schedule" Style="font-size: 18px;" />
				Starttid
			</label>
			<input type="datetime-local" class="form-select"
				   value="@_startTime?.ToString("yyyy-MM-ddTHH:mm")"
				   @onchange="OnStartTimeChanged"
				   disabled="@(_isComboMode && _comboStep == 2)" />
		</section>

		@*End time*@
		@if (_endTime.HasValue)
		{
			<section class="form-field">
				<label class="field-label">
					<RadzenIcon Icon="schedule" Style="font-size: 18px;"/>
					Sluttid: @_endTime.Value.ToString("dd/MM/yyyy HH:mm")
					<button class="edit-btn" @onclick="ToggleEndTimeEdit" type="button">
						<RadzenIcon Icon="@(_editEndTime ? "close" : "edit")" Style="font-size: 16px;"/>
					</button>
				</label>

				@if (_editEndTime)
				{
					<input type="datetime-local" class="form-select"
							value="@_endTime?.ToString("yyyy-MM-ddTHH:mm")"
							@onchange="OnEndTimeChanged" />
				}
			</section>
		}

		@*Sessiontype*@
		<section class="form-field">
			<label class="field-label">
				<span class="step-nr">3</span>
				<RadzenIcon Icon="healing" Style="font-size: 18px;" />
				Behandslingstype
			</label>
			<section class="card-grid @(!_startTime.HasValue ? "card-grid--disabled" : "")">
				@foreach (var type in _sessionTypes)
				{
					<button class="card @(type.SessionTypeID == _selectedSessionTypeId ? "card--selected" : "")"
					@onclick="() => SelectSessionType(type.SessionTypeID)"
					disabled="@(!_startTime.HasValue)"
					type="button">
					<RadzenIcon Icon="healing" Style="font-size: 22px;" />
					<span class="card-title">@type.SessionTypeName</span>
					<span class="card-meta">@GetSessionTypeInMinutes(type) min · @type.SessionTypePrice kr.</span>
				</button>
				}
			</section>
		</section>

		@*Staff*@
		<section class="form-field">
			<label class="field-label">
				<span class="step-nr">4</span>
				<RadzenIcon Icon="medical_services" Style="font-size: 18px;" />
				Behandler
			</label>
			<section class="card-grid @(_selectedSessionTypeId == Guid.Empty ? "card-grid--disabled" : "")">
				@foreach (var staff in _filteredStaff)
				{
					<button class="card @(staff.StaffID == _selectedStaffId ? "card--selected" : "")"
					@onclick="() => SelectStaff(staff.StaffID)"
					disabled="@(_selectedSessionTypeId == Guid.Empty)"
					type="button">
				<span class="card-avatar">
					<RadzenIcon Icon="person" Style="font-size: 24px;" />
				</span>
				<span class="card-title">@staff.StaffFirstName @staff.StaffLastName</span>
				<span class="card-meta">@staff.StaffAuthorisationType</span>
				</button>
				}
			</section>
		</section>


		@*Room*@
		<section class="form-field">
			<label class="field-label">
				<span class="step-nr">5</span>
				<RadzenIcon Icon="meeting_room" Style="font-size: 18px;" />
				Rum
			</label>
			<section class="card-grid @(_selectedStaffId == Guid.Empty ? "card-grid--disabled" : "")">
				@foreach (var room in _rooms)
				{
					<button class="card @(room.RoomID == _selectedRoomId ? "card--selected" : "")"
							@onclick="() => SelectRoom(room.RoomID)"
							disabled="@(_selectedStaffId == Guid.Empty)"
							type="button">
						<RadzenIcon Icon="meeting_room" Style="font-size: 22px;" />
						<span class="card-title">Rum @room.RoomNumber</span>
					</button>
				}
			</section>
		</section>

		@*Promotion*@
		<section class="form-field">
			<label class="field-label">
				<span class="step-nr">6</span>
				<RadzenIcon Icon="sell" Style="font-size: 18px;" />
				Promotion (Valgfri)
			</label>
			<select class="form-select" @onchange="OnPromotionChanged">
				<option value="">- Ingen kampagne -</option>
				@foreach (var promotion in _promotions)
				{
					<option value="@promotion.PromotionID">
						@promotion.PromotionName - @promotion.PromotionDiscountPercent%
					</option>
				}
			</select>
		</section>

		@*Session form*@
		<aside class="summary">
			<p class="summary-title">Booking oversigt</p>
			<ul class="summary-list">

				@if (_selectedClientId != Guid.Empty)
				{
					var client = _clients.FirstOrDefault(c => c.ClientID == _selectedClientId);
					<li><RadzenIcon Icon="person" Style="font-size: 14px;" /> @client.ClientFirstName @client.ClientLastName</li>
				}

				@if (_selectedSessionTypeId != Guid.Empty)
				{
					var sessionType = _sessionTypes.FirstOrDefault(st => st.SessionTypeID == _selectedSessionTypeId);
					<li><RadzenIcon Icon="healing" Style="font-size: 14px;" /> @sessionType.SessionTypeName</li>
				}

				@if (_selectedStaffId != Guid.Empty)
				{
					var staff = _staffInClinic.FirstOrDefault(s => s.StaffID == _selectedStaffId);
					<li><RadzenIcon Icon="medical_services" Style="font-size: 14px;" /> @staff.StaffFirstName @staff.StaffLastName</li>
				}

				@if (_selectedRoomId != Guid.Empty)
				{
					var room = _rooms.FirstOrDefault(r => r.RoomID == _selectedRoomId);
					<li><RadzenIcon Icon="meeting_room" Style="font-size: 14px;" /> Rum @room.RoomNumber</li>
				}

				@if (_startTime.HasValue)
				{
					<li>
						<RadzenIcon Icon="schedule" Style="font-size: 14px;" />
						@_startTime.Value.ToString("dd/MM/yyyy HH:mm")

						@if (_endTime.HasValue)
						{
							<span> Til @_endTime.Value.ToString("HH:mm")</span>
						}
					</li>
				}


			</ul>
		</aside>

		@*Buttons*@
		<footer class="action-footer">
			<button class="submit-button" @onclick="Cancel">
				Annuller
			</button>
			<button class="submit-button" @onclick="Submit"
					disabled="@(!CanSubmit || _isLoading)">
				@if (_isLoading)
				{
					<span>"Gemmer..."</span>
				}
				else if (_isComboMode && _comboStep == 1)
				{
					<span>Næste session →</span>
				}
				else if (_isComboMode && _comboStep == 2)
				{
					<span>Opret begge sessioner</span>
				}
				else
				{
				@(_isEditMode ? "Gem ændringer" : "Opret booking")
				}
				</button>
		</footer>

	</article> 
</main>