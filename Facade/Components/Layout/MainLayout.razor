@using Radzen.Blazor;
@inherits LayoutComponentBase
@inject NavigationManager Nav

<nav class="topnav" aria-label="Main navigation">

    <NavLink href="/" class="nav-logo" Match="NavLinkMatch.All">
        <RadzenIcon Icon="physical_therapy" />
        <span class="logo-text">FysioFunc</span>
    </NavLink>

    <ul class="nav-links" role="list">
        <li><NavLink href="@AppendSession("clients")">
            <RadzenIcon Icon="group" />Clients
        </NavLink></li>
        <li><NavLink href="@AppendSession("promotions")">
            <RadzenIcon Icon="sell" />Promotions
        </NavLink></li>
        <li><NavLink href="@AppendSession("sessions")">
            <RadzenIcon Icon="event_note" />Sessions
        </NavLink></li>
        <li><NavLink href="@AppendSession("bookings")">
            <RadzenIcon Icon="calendar_month" />Bookings
        </NavLink></li>
        <li><NavLink href="@AppendSession("statistics")">
            <RadzenIcon Icon="bar_chart" />Statistics
        </NavLink></li>
    </ul>

    <aside class="nav-right">
        @if (!string.IsNullOrEmpty(ClinicId) && !string.IsNullOrEmpty(StaffId))
        {
            <RadzenIcon Icon="location_on" />
            <span>@ClinicId</span>
            <span class="separator">·</span>
            <RadzenIcon Icon="account_circle" />
            <span>@StaffId</span>
        }
    </aside>

</nav>

<main>
    @Body
</main>

@code {
    [SupplyParameterFromQuery] private string? ClinicId { get; set; }
    [SupplyParameterFromQuery] private string? StaffId  { get; set; }

    private string AppendSession(string page) =>
        $"/{page}?clinicId={ClinicId}&staffId={StaffId}";
}